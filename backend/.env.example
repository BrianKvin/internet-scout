# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/internet_scout

# ── Optional but recommended ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Notifications (free tiers) ────────────────────────────────────────────────
# Resend: https://resend.com — 3,000 free emails/month
# RESEND_API_KEY=re_...
# NOTIFY_EMAIL=you@yourdomain.com

# Slack incoming webhook: free
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Future paid additions ─────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...        # AI scrape config + fit scoring + email drafts
# VOYAGE_API_KEY=pa-...               # CV + job embeddings (pgvector)
# HUNTER_API_KEY=...                  # Verified email lookup ($49/mo)
# CRUNCHBASE_API_KEY=...              # Funding round signals ($29/mo)

# ── App settings ──────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,https://startscout.vercel.app
